{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://agentpilot-production-34c7.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://agentpilot-production-34c7.up.railway.app/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
